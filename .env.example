# ==========================================
# CYPHER Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# DO NOT commit .env file to version control!
#
# Required: Variables marked as "required" MUST be set
# Optional: Variables marked as "optional" can be left empty or omitted

# ==========================================
# APPLICATION (required)
# ==========================================
NODE_ENV=development
PORT=5000

# Frontend URL for CORS - required for production
FRONTEND_URL=http://localhost:3000

# ==========================================
# DATABASE - PostgreSQL (required)
# ==========================================
# Format: postgresql://user:password@host:5432/database?sslmode=require
# Example: postgresql://myuser:mypassword@localhost:5432/CYPHER
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: SSL certificate for some hosting providers (Railway, etc.)
# Copy the certificate content as a single line
# DB_SSL_CERT=

# ==========================================
# JWT AUTHENTICATION (required)
# ==========================================
# Generate a strong random string (at least 32 characters)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Auth cookie name (used for httpOnly cookie)
AUTH_TOKEN=auth_token_name



# ==========================================
# STRIPE - Payment Processing (optional)
# ==========================================
# Required for payment functionality
# Get keys from: https://dashboard.stripe.com/apikeys
# Create webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ==========================================
# GOOGLE OAuth (optional)
# ==========================================
# Required for Google login functionality
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ==========================================
# EMAIL - SMTP Configuration (optional)
# ==========================================
# Required for email functionality (password reset, verification)
# You can use services like:
# - SendGrid (sendgrid.com)
# - Mailgun (mailgun.com)
# - Amazon SES
# - Gmail SMTP
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-email-password
MAIL_FROM=CYPHER <noreply@example.com>

# ==========================================
# PUSHER - Real-time Communication (required)
# ==========================================
# Get credentials from: https://dashboard.pusher.com/
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-app-key
PUSHER_SECRET=your-app-secret
PUSHER_CLUSTER=eu

# ==========================================
# SOCKET.IO (optional - advanced)
# ==========================================
# Used by WebSocket gateway for CORS
# SOCKET_CORS_ORIGIN=http://localhost:3001

# ==========================================
# CACHE (optional - advanced)
# ==========================================
# Cache TTL in seconds (default: 600)
# CACHE_TTL=60

# Maximum items in cache (default: 100)
# CACHE_MAX_ITEMS=100

# ==========================================
# RATE LIMITING (optional - advanced)
# ==========================================
# Time to live in milliseconds (default: 60000)
# THROTTLE_TTL=60000

# Maximum requests per TTL (default: 100)
# THROTTLE_LIMIT=100